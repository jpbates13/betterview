# Optional override for scripts that need a project root path.
# Leave unset to use the current script directory.
SPENDING_TRACKER_DIR=

# Frontend OAuth config (Vite)
VITE_GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Optional Vite dev server host allowlist entry (e.g. your Tailscale URL)
VITE_ALLOWED_HOST=your-machine.tailxxxx.ts.net
